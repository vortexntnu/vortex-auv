<?xml version="1.0"?>
<robot name="orca" xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="base_link"></link>

  <link name="imu_link"></link>

  <link name="dvl_link"></link>

  <link name="pressure_sensor_link"></link>

  <link name="sonar_link"></link>

  <link name="front_camera_link"/>

  <link name="downwards_camera_link"/>

  <!-- base to imu. NB! Needs updated position once mounted on drone! -->
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.1 -0.001 0.085" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- base to dvl -->
  <joint name="base_to_dvl" type="fixed">
    <parent link="base_link"/>
    <child link="dvl_link"/>
    <origin xyz="-0.130 0.003 0.2414" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- base to pressure sensor -->
  <joint name="base_to_pressure_sensor" type="fixed">
    <parent link="base_link"/>
    <child link="pressure_sensor_link"/>
    <origin xyz="-0.130 0.003 0.2414" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- base to fls -->
  <joint name="base_to_fls" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_link"/>
    <origin xyz="0.271721 0.0 -0.203397" rpy="0.0 0.0 0.0"/>
  </joint>

  <xacro:include filename="flir_blackfly_s.urdf.xacro"/>
  <joint name="base_to_downwards_camera" type="fixed">
    <parent link="base_link"/>
    <child link="downwards_camera_link"/>
    <origin xyz="0.283615 -0.085021 0.094186" rpy="-1.5708 -1.5708 -1.5708"/>
  </joint>
  <xacro:flir_blackfly_s frame="downwards_camera_link" base="downwards_camera" name="flir_blackfly"/>

  <!-- RealSense -->
  <xacro:include filename="realsense_d555.urdf.xacro"/>
  <joint name="base_to_front_camera" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <origin xyz="0.36362 0.0 -0.023395" rpy="3.14159 0 0"/>
  </joint>

  <xacro:realsense_d555 frame="front_camera_link" base="front_camera" name="realsense"/>

  <!-- Gripper -->
  <link name="shoulder"></link>

  <joint name="shoulder_joint" type="fixed">
    <parent link="base_link"/>
    <child link="shoulder"/>
    <origin xyz="0.282589 0.028 0.115803" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="arm"></link>

  <joint name="nautilus/arm_joint" type="revolute">
    <parent link="shoulder"/>
    <child link="arm"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit lower="-3.14159" upper="3.14159" effort="0" velocity="0"/>
  </joint>

  <link name="finger1"></link>


  <joint name="nautilus/finger_joint1" type="prismatic">
    <parent link="arm"/>
    <child link="finger1"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.70711 0.70711 0.0"/>
    <limit lower="-0.033" upper="0" effort="0" velocity="0"/>
  </joint>

  <link name="finger2"></link>

  <joint name="nautilus/finger_joint2" type="prismatic">
    <parent link="arm"/>
    <child link="finger2"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.70711 -0.70711 0.0"/>
    <limit lower="-0.033" upper="0" effort="0" velocity="0"/>
  </joint>

</robot>
