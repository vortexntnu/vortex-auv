<?xml version="1.0"?>
<!--
  URDF for the Orca AUV.

  Sensor link positions and orientations are taken directly from the
  stonefish scenario file (orca.scn) so that the TF tree published by
  robot_state_publisher matches the frames the simulator produces.
-->
<robot name="orca" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ======================== Base ======================== -->
  <link name="base_link"/>

  <!-- ======================== Sensors ======================== -->

  <link name="imu_link"/>
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.1 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="dvl_link"/>
  <joint name="base_to_dvl" type="fixed">
    <parent link="base_link"/>
    <child link="dvl_link"/>
    <origin xyz="0.4 0.0 0.2" rpy="0.0 0.0 1.571"/>
  </joint>

  <link name="front_camera_link"/>
  <joint name="base_to_front_camera" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <origin xyz="0.45 0.0 -0.02" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="front_camera_optical"/>
  <joint name="front_camera_optical_joint" type="fixed">
    <parent link="front_camera_link"/>
    <child link="front_camera_optical"/>
    <origin xyz="0.0 0.0 0.0" rpy="1.571 0.0 1.571"/>
  </joint>

  <link name="downwards_camera_link"/>
  <joint name="base_to_downwards_camera" type="fixed">
    <parent link="base_link"/>
    <child link="downwards_camera_link"/>
    <origin xyz="0.4 0.0 0.2" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="downwards_camera_optical"/>
  <joint name="downwards_camera_optical_joint" type="fixed">
    <parent link="downwards_camera_link"/>
    <child link="downwards_camera_optical"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 1.571"/>
  </joint>

</robot>
